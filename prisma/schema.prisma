generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Խանութի աշխատակից — ադմին, մենեջեր, աշխատող
enum Role {
  ADMIN
  MANAGER
  WORKER
}

enum RepairStatus {
  IN_PROGRESS
  READY_FOR_PICKUP
  COMPLETED
}

enum DebtSourceType {
  ACCESSORY_SALE
  REPAIR_ORDER
}

enum DebtStatus {
  ACTIVE
  PARTIALLY_PAID
  PAID
  OVERDUE
}

model User {
  id                  String               @id @default(cuid())
  phone               String               @unique
  name                String?
  passwordHash        String
  role                Role                 @default(WORKER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
}

/// Գաղտնաբառի վերականգնման միանգամյա թոքեն (հղման մեջ)
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Ակսեսուարների պահեստ/վաճառքի ապրանք
model Accessory {
  id        String          @id @default(cuid())
  name      String
  imageUrl  String?
  costPrice Decimal         @db.Decimal(10, 2)
  quantity  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  sales     AccessorySale[]
}

/// Ակսեսուարի վաճառքի գրառում
model AccessorySale {
  id             String    @id @default(cuid())
  accessoryId    String
  accessory      Accessory @relation(fields: [accessoryId], references: [id], onDelete: Restrict)
  quantity       Int
  unitSalePrice  Decimal   @db.Decimal(10, 2)
  totalSalePrice Decimal   @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  debt           Debt?

  @@index([accessoryId])
  @@index([createdAt])
}

/// Վերանորոգման պատվեր/շահույթ
model RepairOrder {
  id           String       @id @default(cuid())
  deviceName   String
  customerName String
  customerPhone String?
  imageUrl      String?
  expenses     Decimal      @db.Decimal(10, 2)
  netProfit    Decimal      @db.Decimal(10, 2)
  description  String       @db.Text
  status       RepairStatus @default(IN_PROGRESS)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  debt         Debt?
}

/// Կասայից կատարված օրվա լրացուցիչ ծախսեր
model DailyExpense {
  id          String   @id @default(cuid())
  title       String
  amount      Decimal  @db.Decimal(10, 2)
  description String?  @db.Text
  spentAt     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([spentAt])
  @@index([createdAt])
}

/// Պարտք՝ կարող է առաջանալ միայն ակսեսուարի վաճառքից կամ վերանորոգման պատվերից
model Debt {
  id              String         @id @default(cuid())
  sourceType      DebtSourceType
  accessorySaleId String?        @unique
  accessorySale   AccessorySale? @relation(fields: [accessorySaleId], references: [id], onDelete: Restrict)
  repairOrderId   String?        @unique
  repairOrder     RepairOrder?   @relation(fields: [repairOrderId], references: [id], onDelete: Restrict)
  customerName    String
  customerPhone   String
  totalAmount     Decimal        @db.Decimal(10, 2)
  paidAmount      Decimal        @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal        @db.Decimal(10, 2)
  status          DebtStatus     @default(ACTIVE)
  dueDate         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  payments        DebtPayment[]

  @@index([sourceType])
  @@index([status])
  @@index([createdAt])
  @@index([dueDate])
}

/// Պարտքի մարումների պատմություն (մասամբ/ամբողջական)
model DebtPayment {
  id        String   @id @default(cuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([debtId])
  @@index([paidAt])
}
